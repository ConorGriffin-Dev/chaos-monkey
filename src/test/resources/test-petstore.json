{
  "openapi": "3.0.0",
  "info": { "title": "Test Spec", "version": "1.0.0" },
  "paths": {
    "/pet": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 1000
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  },
                  "status": {
                    "type": "string",
                    "enum": ["available", "pending", "sold"]
                  },
                  "active": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pet/{petId}": {
      "get": {
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "schema": {
              "type": "integer"
            }
          }
        ]
      },
      "delete": {
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "schema": {
              "type": "integer"
            }
          }
        ]
      }
    },
    "/pet/findByStatus": {
      "get": {
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["available", "pending", "sold"]
            }
          }
        ]
      }
    }
  }
}